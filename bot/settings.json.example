{
  "settings_version": 4,
  "signals_enabled": true,
  "enabled_binance": true,
  "enabled_bybit": true,
  "top_n_symbols": 250,

  "oi_period_minutes": 10,
  "long_period_minutes": 10,
  "short_period_minutes": 10,
  "oi_rise_percent": 4.0,
  "oi_drop_percent": 4.0,
  "price_rise_percent": 1.2,
  "price_drop_percent": 1.2,

  "pulse_enabled": true,
  "pulse_period_minutes": 5,
  "pulse_oi_rise_percent": 2.5,
  "pulse_oi_drop_percent": 2.5,
  "pulse_price_rise_percent": 0.9,
  "pulse_price_drop_percent": 0.9,

  "flash_enabled": true,
  "flash_window_minutes": [5, 10],
  "flash_price_tiers": [8, 12, 18, 25, 35, 50, 100],
  "flash_min_oi_rise_percent": 2.5,
  "flash_min_oi_drop_percent": 2.5,
  "flash_bypass_oi_tier_pct": 20.0,

  "min_open_interest": 150000,
  "min_oi_change_usd": 75000,
  "require_oi_for_price_only": true,
  "require_both_oi_and_price": true,
  "short_squeeze_min_price": 5.0,
  "short_squeeze_max_oi_change": -1.2,

  "signal_cooldown_seconds": 300,
  "mega_cooldown_seconds": 300,
  "breakout_cooldown_seconds": 300,
  "reversal_cooldown_seconds": 300,
  "max_signals_per_symbol_per_day": 2,
  "priority_score_max": 2,
  "min_signal_score": 1.0,
  "max_signal_score": 4,

  "min_probability_percent": 80,
  "probability_filter_enabled": true,
  "probability_strict": true,
  "min_probability_factors_passed": 5,

  "market_structure_enabled": true,
  "market_structure_hours": 5,
  "signal_chart_enabled": true,
  "signal_chart_source": "tradingview",
  "signal_message_compact": true,

  "telegram_max_per_minute": 5,
  "telegram_min_interval_seconds": 3.0,
  "scan_interval_seconds": 1
}
