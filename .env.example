# Telegram bot token, get from @BotFather
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# Telegram admin user id; only this user can control the bot
TELEGRAM_ADMIN_ID=123456789
# Optional: send signal alerts to a group/channel instead of admin DM (not both)
# Leave empty — signals go to TELEGRAM_ADMIN_ID private chat with the bot
# Pump/dump signals AND liquidation alerts (REKT-style) use this chat when set.
# 1) Add bot to the group
# 2) Send any message in the group
# 3) Open https://api.telegram.org/bot<TOKEN>/getUpdates and find "chat":{"id":-100...}
TELEGRAM_ALERT_CHAT_ID=

# Optional: separate chat for smart post-liquidation analysis (reversal setups).
# REQUIRED for analysis messages — .env.example alone does nothing; copy to .env and fill in.
# Bot waits ~90s after a large liquidation cluster, scores 8 factors, sends brief verdict.
# Steps:
#   1) Create a group/channel for analysis only (can differ from TELEGRAM_ALERT_CHAT_ID)
#   2) Add the bot to that chat
#   3) Send any message there
#   4) Open https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id":-100...}
#   5) Set TELEGRAM_ANALYSIS_CHAT_ID=-100xxxxxxxxxx
#   6) Restart bot → startup log should show "Analysis chat OK"
#   7) Test: /test_analysis in admin DM
TELEGRAM_ANALYSIS_CHAT_ID=

# Optional exchange API keys for future authenticated features
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Scanner tuning (optional — основные настройки в bot/settings.json)
SCAN_INTERVAL_SECONDS=1
SIGNAL_COOLDOWN_SECONDS=90
